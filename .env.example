# --- Raíz o server/.env (ConfigModule carga .env y server/.env) ---
# Copia a .env o server/.env y ajusta. Nunca subas claves a git.

# Puerto en local (Nest; `npm run start:prod` no usa en Vercel)
PORT=5000

# Orígenes del front (CORS, separados por comas, sin barra final)
# Ej. Firebase: https://tu-sitio.web.app,https://tu-dominio.com
# En Vercel, define las mismas URLs reales.
ORIGIN=http://localhost:3000,http://localhost:4200

# Cookies de sesión
COOKIE_KEY=genera-un-secreto-largo-en-producción

# Opcional: same-site entre dominios (front distinto a API) sin ser Vercel
# CROSS_SITE_COOKIES=1

# Firebase Admin (ruta a JSON) — local; en Vercel usa el JSON embebido vía var de entorno si aplica
# GOOGLE_APPLICATION_CREDENTIALS=./server/credentials/...
