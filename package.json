{
  "name": "sj-aura",
  "version": "1.0.0",
  "description": "SJ AURA — tienda (Angular + NestJS)",
  "author": "Johan Rojas",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/johanrojas07/sj-aura-shop.git"
  },
  "scripts": {
    "build:server": "cross-env NODE_ENV=production nest build --config ./server/nest-cli.json",
    "start:server": "cross-env NODE_ENV=production nest start --config ./server/nest-cli.json --path ./server/tsconfig.json",
    "start:dev": "cross-env NODE_ENV=development nest start --watch --config ./server/nest-cli.json --path ./server/tsconfig.json",
    "start:debug": "nest start --debug --watch --config ./server/nest-cli.json --path ./server/tsconfig.json",
    "start:prod": "node server/dist/main",
    "dev": "concurrently -n api,web -c blue,green \"npm run start:dev\" \"npm run start:client\"",
    "seed:firestore": "node ./server/scripts/seed-firestore.cjs",
    "seed:firestore:clear": "node ./server/scripts/seed-firestore.cjs --clear",
    "seed:firestore:reset-products": "node ./server/scripts/seed-firestore.cjs --reset-products",
    "sync:product-images:storage": "node ./server/scripts/seed-firestore.cjs --upload-product-images",
    "format": "prettier --write \"server/**/*.ts\"",
    "lint": "eslint \"server/**/*.ts\" --fix",
    "ng": "ng ",
    "start:client": "ng serve --port 3000",
    "start:client:https": "ng serve --port 3000 --ssl=true --ssl-key=localhost.key --ssl-cert=localhost.crt",
    "build:client": "ng build",
    "watch": "ng build --watch --configuration development",
    "dev:ssr": "ng run eshop:serve-ssr",
    "serve:ssr": "node dist/eshop/server/server.mjs",
    "clean:ng": "ng cache clean",
    "build:ssr": "cross-env NODE_ENV=production ng build --configuration production",
    "build:ssr:clean": "ng cache clean && cross-env NODE_ENV=production ng build --configuration production",
    "prepare:firebase-hosting": "node scripts/prepare-firebase-hosting.cjs",
    "deploy:hosting": "npm run build:ssr && npm run prepare:firebase-hosting && npx firebase deploy --only hosting:ecommerce-afcfb-db103",
    "serve:client:prod": "ng serve --configuration production",
    "lint:client": "ng lint",
    "lint:scss": "stylelint **/**.scss --formatter verbose",
    "lint:scss:fix": "npm run lint:scss -- --fix",
    "release": "standard-version",
    "start": "npm run serve:ssr"
  },
  "dependencies": {
    "@angular/animations": "20.2.2",
    "@angular/cdk": "20.2.2",
    "@angular/common": "20.2.2",
    "@angular/compiler": "20.2.2",
    "@angular/core": "20.2.2",
    "@angular/forms": "20.2.2",
    "@angular/material": "20.2.2",
    "@angular/platform-browser": "20.2.2",
    "@angular/platform-browser-dynamic": "20.2.2",
    "@angular/platform-server": "20.2.2",
    "@angular/router": "20.2.2",
    "@angular/service-worker": "20.2.2",
    "@angular/ssr": "20.2.2",
    "@nestjs/axios": "4.0.1",
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.1",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-express": "^11.1.6",
    "@sendgrid/mail": "^8.1.5",
    "@tinymce/tinymce-angular": "^8.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cloudinary": "^2.2.0",
    "connect-redis": "^7.1.1",
    "cookie-parser": "^1.4.7",
    "deepmerge": "4.3.1",
    "express": "^5.1.0",
    "express-session": "^1.18.1",
    "firebase": "^11.6.0",
    "firebase-admin": "^13.0.0",
    "ngx-cookie-service": "^20.1.0",
    "redis": "^4.7.0",
    "rxjs": "^7.8.1",
    "serverless-http": "^3.2.0",
    "streamifier": "^0.1.1",
    "stripe": "^9.15.0",
    "tinycolor2": "^1.6.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular-devkit/core": "20.2.2",
    "@angular-devkit/schematics": "20.2.2",
    "@angular-eslint/builder": "^20.0.0",
    "@angular-eslint/eslint-plugin": "^20.0.0",
    "@angular-eslint/eslint-plugin-template": "^20.0.0",
    "@angular-eslint/schematics": "^20.0.0",
    "@angular-eslint/template-parser": "^20.0.0",
    "@angular/build": "20.2.2",
    "@angular/cli": "20.2.2",
    "@angular/compiler-cli": "20.2.2",
    "@angular/language-service": "20.2.2",
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^11.0.7",
    "@nestjs/serve-static": "^5.0.3",
    "@types/express": "^5.0.3",
    "@types/express-session": "^1.18.0",
    "@types/node": "^24.2.0",
    "@typescript-eslint/eslint-plugin": "8.39.0",
    "@typescript-eslint/parser": "8.39.0",
    "compression": "^1.8.1",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "fastify-static": "^4.7.0",
    "firebase-tools": "^14.25.0",
    "prettier": "^3.6.2",
    "saslprep": "1.0.3",
    "sass": "^1.81.0",
    "standard-version": "^9.5.0",
    "stylelint": "^15.11.0",
    "stylelint-config-recommended": "^13.0.0",
    "stylelint-config-standard": "^34.0.0",
    "stylelint-scss": "^5.3.0",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "typescript": "5.8.3",
    "whatwg-url": "^14.0.0"
  },
  "engines": {
    "node": ">=20 <25",
    "npm": ">=10"
  },
  "browserslist": [
    "> 5%"
  ]
}
