# Copiar a .env en la raíz de eshop_mean-master o a server/.env (ambos se cargan; no commitear secretos)

PORT=4000
ORIGIN=http://localhost:3000
SERVER_URL=http://localhost:4000

# Sesión (carrito invitado en memoria del proceso Node)
COOKIE_KEY=change-me-long-random

# Firebase Admin + Firestore (obligatorio)
# Opción A: JSON dentro del repo (ignorado por git), ruta relativa a server/:
GOOGLE_APPLICATION_CREDENTIALS=./credentials/firebase-service-account.json
# Opción B: JSON en una sola variable (entornos cloud)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

FIREBASE_PROJECT_ID=tu-proyecto-id
# Bucket de Firebase Storage (nombre en Consola; suele ser PROJECT_ID.firebasestorage.app o .appspot.com).
# FIREBASE_STORAGE_BUCKET=ecommerce-afcfb.firebasestorage.app
# ID de la base en Firestore (consola: selector junto a "Datos"). (default) o nombre p. ej. ecommerce
FIRESTORE_DATABASE_ID=ecommerce

# Imágenes del admin: por defecto Firebase Storage (gratis en plan Spark con límites razonables).
# Forzar Cloudinary si ya lo usas: IMAGE_STORAGE=cloudinary
# IMAGE_STORAGE=firebase

# Pagos / email / admin
STRIPE_SECRETKEY=
SENDGRID_KEY=
EMAIL_FROM=
ADMIN_EMAILS=

# Solo si IMAGE_STORAGE=cloudinary (o como respaldo si Storage falla)
CLOUDINARY_NAME=
CLOUDINARY_KEY=
CLOUDINARY_SECRET=
RECAPTCHA_SERVER_KEY=
GEO_LOCATION_API_KEY=

# Fidelización (teléfono invitado + OTP + auditoría). En producción define siempre un pepper propio.
# LOYALTY_PHONE_PEPPER=genera-un-secreto-largo-aleatorio
# Secreto para digest del código OTP (puede coincidir con el pepper si quieres menos variables).
# LOYALTY_OTP_SECRET=
# Con 1, el servidor loguea el código OTP (solo desarrollo). Integra SMS/WhatsApp para envío real.
# LOYALTY_OTP_DEBUG=0
# Peligroso: otorga puntos a invitados sin verificar OTP en el pedido (no recomendado en producción).
# LOYALTY_GUEST_SKIP_ORDER_OTP=false

# Listado admin de clientes con puntos (límite de lecturas Firestore por petición)
# LOYALTY_ADMIN_MAX_SCAN_USERS=600
# LOYALTY_ADMIN_MAX_SCAN_WALLETS=600
# LOYALTY_ADMIN_AUDIT_ACTIVITY_TAIL=800

# Google Analytics 4 (opcional): ID de medición G-XXXX. El front lo recibe vía GET .../api/eshop/config (JSON con config en base64).
FE_ANALYTICS_TOKEN=
